# ── One Piece Tournament – Environment Variables ─────────────
# Copy this to `.env` and fill in real values for production.
# The .env file is git-ignored and never committed.

# Django
SECRET_KEY=generate-a-long-random-string-here
ALLOWED_HOSTS=localhost,127.0.0.1,yourdomain.com
DJANGO_SETTINGS_MODULE=config.settings.production

# PostgreSQL
POSTGRES_DB=onepiece
POSTGRES_USER=onepiece
POSTGRES_PASSWORD=change-me-strong-password
POSTGRES_HOST=db
POSTGRES_PORT=5432

# Admin superuser (created on first boot)
ADMIN_USER=admin
ADMIN_PASSWORD=change-me-strong-password
ADMIN_EMAIL=admin@yourdomain.com

# HTTPS security (set to 1 when behind a TLS reverse proxy)
# SECURE_SSL_REDIRECT=1
# SESSION_COOKIE_SECURE=1
# CSRF_COOKIE_SECURE=1
# SECURE_HSTS_SECONDS=31536000
# CSRF_TRUSTED_ORIGINS=https://yourdomain.com
